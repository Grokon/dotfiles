[include]
        path = ~/.gitconfig.local

[core]
        autocrlf = input
	editor = code --wait

[help]
        autocorrect = 10

[alias]
        st = status
        co = checkout
        ci = commit
        ca = commit --reset-author --amend
        unmodify = checkout --
        unstage = reset HEAD --
        br = branch
        last = log -1 --format=fuller HEAD
        hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
        type = cat-file -t
        dump = cat-file -p
        tag-list = tag -l -n1
        show-names = show --name-only

[color]
        ui = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[apply]
        whitespace = nowarn


[diff]
	renames = copies
	mnemonicprefix = true

[difftool]
        prompt = false

[init]
        defaultBranch = main

[pull]
        rebase = false

[log]
        decorate = full

[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
